# ===========================================================================
# docker/.env.example — Supabase self-hosted + cursos_amx
# ===========================================================================
# Cópialo a docker/.env y rellena los valores reales antes del primer
# `docker compose up`.
#
# Genera los secretos con:
#   openssl rand -hex 32         # JWT_SECRET, SECRET_KEY_BASE, VAULT_ENC_KEY
#   openssl rand -hex 32         # POSTGRES_PASSWORD, etc.
#   docker run --rm -e JWT_SECRET=$JWT_SECRET supabase/edge-runtime:v1.71.2 \
#       deno run https://supabase.com/docs/_next/data/jwt.ts   # ANON_KEY + SERVICE_ROLE_KEY
# ===========================================================================

############
# Secretos
############
POSTGRES_PASSWORD=cambia-esto
JWT_SECRET=cambia-esto-32-bytes-hex
JWT_EXPIRY=3600
ANON_KEY=<jwt firmado con JWT_SECRET para role anon>
SERVICE_ROLE_KEY=<jwt firmado con JWT_SECRET para role service_role>
SECRET_KEY_BASE=cambia-esto-32-bytes-hex
VAULT_ENC_KEY=cambia-esto-32-bytes-hex
PG_META_CRYPTO_KEY=cambia-esto-32-bytes-hex

DASHBOARD_USERNAME=supabase
DASHBOARD_PASSWORD=cambia-esto

# Opcional: nueva forma de keys asimétricas (sb_publishable_*, sb_secret_*)
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
ANON_KEY_ASYMMETRIC=
SERVICE_ROLE_KEY_ASYMMETRIC=

############
# Postgres
############
POSTGRES_HOST=db
POSTGRES_DB=postgres
POSTGRES_PORT=5432

############
# API / URLs
############
API_EXTERNAL_URL=https://api.tu-dominio.mx
SUPABASE_PUBLIC_URL=https://api.tu-dominio.mx
SITE_URL=https://app.tu-dominio.mx
ADDITIONAL_REDIRECT_URLS=
KONG_HTTP_PORT=8000
KONG_HTTPS_PORT=8443

############
# Auth
############
DISABLE_SIGNUP=false
ENABLE_EMAIL_SIGNUP=true
ENABLE_EMAIL_AUTOCONFIRM=false
ENABLE_PHONE_SIGNUP=false
ENABLE_PHONE_AUTOCONFIRM=false
ENABLE_ANONYMOUS_USERS=false

############
# Mailer (SMTP)
############
SMTP_ADMIN_EMAIL=admin@tu-dominio.mx
SMTP_HOST=smtp.tu-proveedor.mx
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SENDER_NAME=CursosAMX

MAILER_URLPATHS_INVITE=/auth/v1/verify
MAILER_URLPATHS_CONFIRMATION=/auth/v1/verify
MAILER_URLPATHS_RECOVERY=/auth/v1/verify
MAILER_URLPATHS_EMAIL_CHANGE=/auth/v1/verify

############
# REST / Schemas
############
PGRST_DB_SCHEMAS=public,storage,graphql_public
PGRST_DB_MAX_ROWS=1000
PGRST_DB_EXTRA_SEARCH_PATH=public,extensions

############
# Studio
############
STUDIO_DEFAULT_ORGANIZATION=CursosAMX
STUDIO_DEFAULT_PROJECT=cursos
OPENAI_API_KEY=

############
# Analytics
############
LOGFLARE_PUBLIC_ACCESS_TOKEN=cambia-esto
LOGFLARE_PRIVATE_ACCESS_TOKEN=cambia-esto

############
# Storage
############
GLOBAL_S3_BUCKET=stub
STORAGE_TENANT_ID=stub
REGION=stub
S3_PROTOCOL_ACCESS_KEY_ID=
S3_PROTOCOL_ACCESS_KEY_SECRET=

############
# Imgproxy
############
IMGPROXY_AUTO_WEBP=true

############
# Pooler
############
POOLER_TENANT_ID=stub
POOLER_DEFAULT_POOL_SIZE=10
POOLER_MAX_CLIENT_CONN=200
POOLER_DB_POOL_SIZE=5
POOLER_PROXY_PORT_TRANSACTION=6543

############
# Edge Functions
############
FUNCTIONS_VERIFY_JWT=false

############
# Docker
############
DOCKER_SOCKET_LOCATION=/var/run/docker.sock

############
# video-worker (custom)
############
INGEST_BUCKET=video-ingest
HLS_BUCKET=video-hls
MAX_CONCURRENT=1

############
# nginx-certbot override (solo si usas overrides/nginx.yml)
############
PROXY_DOMAIN=api.tu-dominio.mx
CERTBOT_EMAIL=admin@tu-dominio.mx
