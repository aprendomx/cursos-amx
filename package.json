{
  "name": "cursos-amx",
  "version": "0.20.0",
  "description": "LMS open source con video HLS, evaluaciones y constancias verificables. Personalizable por capa de tema.",
  "license": "AGPL-3.0-only",
  "author": "Julio Adrián <jadrian.s@gmail.com>",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "type-check": "vue-tsc --noEmit",
    "format": "prettier --write .",
    "prepare": "husky",
    "test:unit": "vitest run",
    "test:unit:cov": "vitest run --coverage",
    "test:unit:watch": "vitest",
    "test:e2e": "playwright test",
    "test:perf": "playwright test e2e/performance.spec.js",
    "prerender": "node scripts/prerender.js"
  },
  "dependencies": {
    "@sentry/vue": "^10.67.0",
    "@supabase/supabase-js": "^2.110.8",
    "@tiptap/core": "^3.28.0",
    "@tiptap/extension-image": "^3.28.0",
    "@tiptap/extension-link": "^3.27.1",
    "@tiptap/extension-placeholder": "^3.28.0",
    "@tiptap/starter-kit": "^3.28.0",
    "@tiptap/vue-3": "^3.28.0",
    "chart.js": "^4.5.1",
    "hls.js": "^1.6.16",
    "html2pdf.js": "^0.14.0",
    "idb": "^8.0.3",
    "pinia": "^3.0.4",
    "qrcode.vue": "^3.10.0",
    "tus-js-client": "^4.3.1",
    "vue": "^3.5.40",
    "vue-draggable-plus": "^0.6.1",
    "vue-i18n": "^11.4.7",
    "vue-router": "^4.6.4"
  },
  "lint-staged": {
    "*.{js,vue}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,md,json,html,yml,yaml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@sentry/vite-plugin": "^5.4.0",
    "@types/node": "^26.1.1",
    "@vitejs/plugin-vue": "^5.2.4",
    "@vitest/coverage-v8": "^4.1.10",
    "@vue/test-utils": "^2.4.11",
    "eslint": "^10.7.0",
    "eslint-plugin-vue": "^10.10.0",
    "fake-indexeddb": "^6.2.5",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.2.0",
    "prettier": "^3.9.6",
    "sharp": "^0.35.3",
    "typescript": "^6.0.3",
    "vite": "^6.3.2",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.9",
    "vue-tsc": "^3.3.8"
  }
}
