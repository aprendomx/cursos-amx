# ===========================================================================
# Frontend (Vite) — .env de la raíz
# ===========================================================================
# Usado por la app Vue en `npm run dev` y `npm run build`. NO confundir con
# `docker/.env` (que configura el stack Supabase + worker en producción).
# ===========================================================================

VITE_SUPABASE_URL=https://api.tu-dominio.org
VITE_SUPABASE_ANON_KEY=tu-anon-key-aqui

# ── Feature flags de módulos LMS (true/false; ver src/lib/featureFlags.js) ──
# instructor viene encendido por default; el resto apagado hasta implementarse.
VITE_FEATURE_INSTRUCTOR=true
VITE_FEATURE_FOROS=false
VITE_FEATURE_CHAT=false
VITE_FEATURE_ENTREGAS=false
VITE_FEATURE_AULAS=false

# Instancia de Jitsi para las aulas virtuales (sin https://).
# Default: la instancia pública meet.jit.si
VITE_JITSI_DOMAIN=meet.jit.si

# Sentry error tracking (optional)
VITE_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# ── Transcripción (Whisper) ──
# URL del servicio faster-whisper local (default). Comenta para usar OpenAI directamente.
WHISPER_SERVICE_URL=http://whisper-service:5000
# Fallback a OpenAI si faster-whisper no responde (opcional)
OPENAI_API_KEY=

# Configuración del servicio faster-whisper (solo si usas docker-compose)
WHISPER_MODEL=medium       # tiny, base, small, medium, large-v2, distil-large-v3
WHISPER_DEVICE=cpu         # cpu | cuda
WHISPER_COMPUTE_TYPE=int8  # int8 (cpu), float16 (cuda), float32
WHISPER_PORT=5000
WHISPER_MEMORY_LIMIT=4G
